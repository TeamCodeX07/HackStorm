# Firebase Admin SDK Configuration
# Service account credentials for Firebase Admin SDK
# Download from Firebase Console: Project Settings > Service Accounts > Generate New Private Key
# Store the entire JSON content as a string, or use a path to the JSON file
# Format: '{"type":"service_account","project_id":"...","private_key":"...",...}'
FIREBASE_SERVICE_ACCOUNT_JSON=your_firebase_service_account_json_here

# Database Configuration
# MongoDB connection string for storing fact-checks, user data, and analysis results
# Format: mongodb://username:password@host:port/database
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/truthlens

# AI Model Configuration
# Cerebras API key for fast inference using Cerebras cloud platform
# Used for AI-powered content analysis and fact-checking
# Get your API key from: https://cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Search API Configuration
# SerpAPI key for retrieving real-time search results from Google, Bing, etc.
# Used for gathering evidence and sources during fact-checking process
# Get your API key from: https://serpapi.com
SERP_API_KEY=your_serp_api_key_here

# Media Verification Configuration
# Reality Defender API key for detecting AI-generated or manipulated media
# Used for deepfake detection and media authenticity verification
# Get your API key from: https://realitydefender.com
REALITY_DEFENDER_API_KEY=your_reality_defender_api_key_here

# CORS Configuration
# Frontend application URL for CORS policy
# Development: http://localhost:3000
# Production: https://truthlens.com
FRONTEND_URL=http://localhost:3000

# Application Environment
# Determines the running environment (development, production, test)
# Affects logging, error handling, and feature availability
NODE_ENV=development

# Server Configuration (Optional)
# Port number for the backend server (default: 5000)
# PORT=5000
