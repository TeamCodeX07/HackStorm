# Firebase Configuration
# Get these values from your Firebase project settings (Project Settings > General > Your apps)
# Used for client-side Firebase authentication and services

# Firebase API key for web client authentication
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase authentication domain (usually <project-id>.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# Firebase project identifier
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here

# Firebase storage bucket URL (usually <project-id>.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# Backend API Configuration
# Base URL for the TruthLens backend API
# Development: http://localhost:5000
# Production: https://api.truthlens.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
